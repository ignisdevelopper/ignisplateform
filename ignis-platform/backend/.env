# ─────────────────────────────────────────────────────────────────────────────
# IGNIS Platform — .env (template)
# Copie ce fichier en .env et remplis les valeurs nécessaires.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=dev
DEBUG=true
APP_NAME=IGNIS Platform
API_PREFIX=/api/v1

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ENABLED=true
CORS_ORIGINS=["*"]
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
CORS_ALLOW_CREDENTIALS=true

# (optionnel) Clé API simple si tu veux protéger certains endpoints
# IGNIS_API_KEY=change-me

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false

# ── Database ────────────────────────────────────────────────────────────────
# Option 1 (dev rapide) : SQLite async
SQLITE_FILE=./ignis.db
# Option 2 : PostgreSQL async (décommente)
# DATABASE_URL=postgres+asyncpg://user:password@localhost:5432/ignis

DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# DEV ONLY: crée les tables au démarrage (en prod => Alembic)
DB_CREATE_ALL=false

# ── Redis / Cache ───────────────────────────────────────────────────────────
CACHE_NAMESPACE=ignis
CACHE_USE_REDIS=true

# Option 1 : URL complète
# REDIS_URL=redis://localhost:6379/0
# Option 2 : host/port/db
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# TTL (secondes)
CACHE_CANDLES_TTL=300
CACHE_ANALYSIS_TTL=60
CACHE_SETUP_TTL=120
CACHE_ASSET_LIST_TTL=3600

# ── WebSocket ───────────────────────────────────────────────────────────────
WS_PING_INTERVAL=25
WS_PING_TIMEOUT=10
WS_MAX_CONNECTIONS=500

# ── API Limits ──────────────────────────────────────────────────────────────
MAX_CANDLES_PER_REQUEST=5000
RATE_LIMIT_PER_MINUTE=120
ANALYSIS_TIMEOUT_SECONDS=30

# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=8660794874:AAFdPaoZcHgxIwdTHgICchUrbkWRn_KfJlE
# Optionnel: auto-register des chats au démarrage (main.py)
TELEGRAM_CHAT_IDS=signaux330

# ── Ollama / Ignis AI ────────────────────────────────────────────────────────
IGNIS_AI_ENABLED=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_S=120

IGNIS_AI_TEMPERATURE=0.2
IGNIS_AI_TOP_P=0.9
IGNIS_AI_NUM_CTX=8192
IGNIS_AI_MAX_INPUT_CHARS=20000
IGNIS_AI_MAX_MESSAGES=50
IGNIS_AI_SESSION_TTL=3600
IGNIS_AI_SESSION_CLEANUP_INTERVAL=60
IGNIS_AI_MAX_REQ_PER_MINUTE=60

# ── Binance fetcher (optionnel) ─────────────────────────────────────────────
BINANCE_BASE_URL=https://api.binance.com
BINANCE_CONNECT_TIMEOUT=10
BINANCE_READ_TIMEOUT=30
BINANCE_MAX_RETRY=6
BINANCE_RETRY_BASE_DELAY=0.8
BINANCE_RETRY_MAX_DELAY=20

# ── Feature Flags (pipeline) ────────────────────────────────────────────────
FF_MARKET_STRUCTURE=true
FF_BASE_ENGINE=true
FF_SD_ZONES=true
FF_PA_PATTERNS=true
FF_ADVANCED_PATTERNS=true
FF_DECISION_POINTS=true
FF_SL_TP=true
FF_PULLBACK_ENTRY=true

# ── Seed data (dev) ─────────────────────────────────────────────────────────
IGNIS_SEED_ASSETS=true
IGNIS_SEED_TELEGRAM_CHATS=false
IGNIS_SEED_PRICE_ALERTS=false
IGNIS_SEED_TELEGRAM_CHAT_IDS=signaux330
IGNIS_SEED_TELEGRAM_MIN_PRIORITY=MEDIUM
IGNIS_SEED_TELEGRAM_SILENT_START=0
IGNIS_SEED_TELEGRAM_SILENT_END=0